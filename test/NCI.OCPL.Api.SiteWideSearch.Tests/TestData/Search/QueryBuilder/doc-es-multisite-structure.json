{
    "bool": {
        "filter": {
            "term": { "metatag.content-language": { "value": "es" } }
        },
        "must": [
            {
                "bool": {
                    "minimum_should_match": 1,
                    "must": {
                        "exists": { "field": "searchtitle" }
                    },
                    "should": [
                        { "prefix": { "searchurl.raw": { "value": "www.cancer.gov/pediatric-adult-rare-tumor/espanol" } } },
                        { "prefix": { "searchurl.raw": { "value": "www.cancer.gov/rare-brain-spine-tumor/espanol" } } }
                    ]
                }
            },
            {
                "bool": {
                    "should": [
                        { "match": { "content.es": { "operator": "and", "query": "pollo", "boost": 1 } } },
                        { "match": { "searchtitle.es": { "query": "pollo", "boost": 1 } } },
                        { "match": { "searchurl.es": { "query": "pollo", "boost": 1 } } },
                        { "match_phrase": { "content.es": { "query": "pollo", "boost": 1 } } },
                        {
                            "bool": {
                                "should": {
                                    "match": { "metatag.description.es": { "query": "pollo", "boost": 0.01 } }
                                }
                            }
                        }
                    ]
                }
            }
        ],
        "should": {
            "term": { "type": { "value": "text/html", "boost": 1 } }
        }
    }
}